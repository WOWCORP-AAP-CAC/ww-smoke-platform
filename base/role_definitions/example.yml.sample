---
# Example custom role definitions — rename to .yml to activate.
# This file belongs in base/role_definitions/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/role_definitions/.
gateway_role_definitions:
  - name: "Example Inventory Viewer"
    description: "Example custom role — replace with your RBAC role"
    content_type: awx.inventory
    permissions:
      - awx.view_inventory
