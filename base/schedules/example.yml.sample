---
# Example platform schedules configuration — rename to .yml to activate.
# This file belongs in base/schedules/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/schedules/.
controller_schedules:
  - name: sch-platform-example
    description: "Example platform schedule — replace with your schedule"
    unified_job_template: jt-platform-casc_dispatcher
    rrule: "DTSTART;TZID=UTC:20260101T060000 RRULE:FREQ=DAILY;INTERVAL=1"
    enabled: false
