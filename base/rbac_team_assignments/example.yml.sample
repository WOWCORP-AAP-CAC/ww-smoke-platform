---
# Example RBAC team assignments — rename to .yml to activate.
# This file belongs in base/rbac_team_assignments/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/rbac_team_assignments/.
gateway_role_team_assignments:
  - team: "Example Team"
    role_definition: "Organization Execute"
    assignment_objects:
      - name: "Example Organization"
        type: organizations
