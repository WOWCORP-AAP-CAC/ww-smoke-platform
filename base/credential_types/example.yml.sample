---
# Example credential types configuration — rename to .yml to activate.
# This file belongs in base/credential_types/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/credential_types/.
controller_credential_types:
  - name: "Example Custom Credential Type"
    description: "Example credential type — replace with your type"
    kind: cloud
    inputs:
      fields:
        - id: api_key
          type: string
          label: API Key
          secret: true
    injectors:
      extra_vars:
        my_api_key: "{{ api_key }}"
