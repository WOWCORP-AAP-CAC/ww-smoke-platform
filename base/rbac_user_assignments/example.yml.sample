---
# Example RBAC user assignments — rename to .yml to activate.
# This file belongs in base/rbac_user_assignments/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/rbac_user_assignments/.
gateway_role_user_assignments:
  - user: example_user
    role_definition: "Organization Admin"
    object_ids: "Example Organization"
